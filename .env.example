# Copie este arquivo para ".env" e preencha com as chaves reais do Firebase.
# O .env real NUNCA deve ser commitado (já está no .gitignore).
# Na Vercel: adicione as mesmas chaves em Settings > Environment Variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
